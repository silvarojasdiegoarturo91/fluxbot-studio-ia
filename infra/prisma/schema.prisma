// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// ENUMS
// ============================================================================

enum ShopStatus {
  ACTIVE
  SUSPENDED
  CANCELLED
  TRIAL
}

enum UserRole {
  OWNER
  ADMIN
  VIEWER
}

enum ConversationChannel {
  WEB_CHAT
  WHATSAPP
  INSTAGRAM
  EMAIL
  SMS
}

enum ConversationStatus {
  ACTIVE
  ESCALATED
  RESOLVED
  ABANDONED
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
  TOOL
}

enum KnowledgeSourceType {
  CATALOG
  POLICIES
  PAGES
  BLOG
  FAQ
  CUSTOM
}

enum SyncStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum ConsentType {
  CHAT_STORAGE
  ANALYTICS
  PERSONALIZATION
  MARKETING
}

// ============================================================================
// TENANT & IDENTITY
// ============================================================================

model Shop {
  id                 String             @id @default(uuid())
  domain             String             @unique
  accessToken        String
  scope              String?
  isOnline           Boolean            @default(false)
  status             ShopStatus         @default(ACTIVE)
  plan               String?
  metadata           Json?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  
  // Relations
  installations      ShopInstallation[]
  users              User[]
  chatbotConfigs     ChatbotConfig[]
  conversations      Conversation[]
  knowledgeSources   KnowledgeSource[]
  consentRecords     ConsentRecord[]
  auditLogs          AuditLog[]
  syncJobs           SyncJob[]
  behaviorEvents     BehaviorEvent[]
  intentSignals      IntentSignal[]
  proactiveTriggers  ProactiveTrigger[]
  proactiveMessages  ProactiveMessage[]
  callbackReceipts   OmnichannelCallbackReceipt[]
  deadLetterCallbacks DeadLetterCallback[]
  handoffRequests    HandoffRequest[]
  conversionEvents   ConversionEvent[]
  dataExportJobs     DataExportJob[]
  dataDeletionJobs   DataDeletionJob[]
  
  @@map("shops")
}

model ShopInstallation {
  id                 String    @id @default(uuid())
  shopId             String
  installedAt        DateTime  @default(now())
  uninstalledAt      DateTime?
  billingPlan        String?
  billingStatus      String?
  featureFlags       Json?
  
  shop               Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  
  @@map("shop_installations")
}

model User {
  id                 String    @id @default(uuid())
  shopId             String
  email              String
  firstName          String?
  lastName           String?
  role               UserRole  @default(VIEWER)
  isActive           Boolean   @default(true)
  lastLoginAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  
  shop               Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  
  @@unique([shopId, email])
  @@map("users")
}

model Session {
  id                 String    @id
  shop               String
  state              String
  isOnline           Boolean   @default(false)
  scope              String?
  expires            DateTime?
  accessToken        String
  userId             BigInt?
  firstName          String?
  lastName           String?
  email              String?
  accountOwner       Boolean   @default(false)
  locale             String?
  collaborator       Boolean?  @default(false)
  emailVerified      Boolean?  @default(false)
  
  @@map("session")
}

// ============================================================================
// CONFIGURATION
// ============================================================================

model ChatbotConfig {
  id                 String    @id @default(uuid())
  shopId             String
  name               String    @default("AI Assistant")
  tone               String?   @default("professional")
  language           String    @default("en")
  temperature        Float     @default(0.7)
  maxTokens          Int       @default(500)
  systemPrompt       String?
  userPrompt         String?
  enableProactive    Boolean   @default(false)
  enableHandoff      Boolean   @default(true)
  confidenceThreshold Float    @default(0.6)
  isActive           Boolean   @default(true)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  
  shop               Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  aiProviderConfigs  AIProviderConfig[]
  
  @@unique([shopId])
  @@map("chatbot_configs")
}

model AIProviderConfig {
  id                 String    @id @default(uuid())
  chatbotConfigId    String
  provider           String    // 'openai', 'anthropic', 'gemini'
  apiKey             String
  model              String
  isPrimary          Boolean   @default(false)
  isActive           Boolean   @default(true)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  
  chatbotConfig      ChatbotConfig @relation(fields: [chatbotConfigId], references: [id], onDelete: Cascade)
  
  @@map("ai_provider_configs")
}

// ============================================================================
// CONVERSATIONS
// ============================================================================

model Conversation {
  id                 String              @id @default(uuid())
  shopId             String
  channel            ConversationChannel @default(WEB_CHAT)
  status             ConversationStatus  @default(ACTIVE)
  visitorId          String?
  customerId         String?
  sessionId          String?
  locale             String              @default("en")
  metadata           Json?
  startedAt          DateTime            @default(now())
  endedAt            DateTime?
  lastMessageAt      DateTime?
  
  shop               Shop                @relation(fields: [shopId], references: [id], onDelete: Cascade)
  messages           ConversationMessage[]
  events             ConversationEvent[]
  customerIdentity   CustomerIdentity?
  handoffRequests    HandoffRequest[]
  conversionEvents   ConversionEvent[]
  
  @@index([shopId, startedAt])
  @@index([customerId])
  @@map("conversations")
}

model ConversationMessage {
  id                 String       @id @default(uuid())
  conversationId     String
  role               MessageRole
  content            String
  confidence         Float?
  tokensUsed         Int?
  cost               Float?
  metadata           Json?
  createdAt          DateTime     @default(now())
  
  conversation       Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  toolInvocations    ToolInvocation[]
  
  @@index([conversationId, createdAt])
  @@map("conversation_messages")
}

model ConversationEvent {
  id                 String       @id @default(uuid())
  conversationId     String
  eventType          String       // 'page_view', 'exit_intent', 'scroll', 'click'
  eventData          Json?
  timestamp          DateTime     @default(now())
  
  conversation       Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  
  @@index([conversationId, timestamp])
  @@map("conversation_events")
}

model CustomerIdentity {
  id                 String       @id @default(uuid())
  conversationId     String       @unique
  customerId         String?
  email              String?
  phone              String?
  verified           Boolean      @default(false)
  verificationMethod String?
  createdAt          DateTime     @default(now())
  
  conversation       Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  
  @@map("customer_identities")
}

// ============================================================================
// KNOWLEDGE & RAG
// ============================================================================

model KnowledgeSource {
  id                 String              @id @default(uuid())
  shopId             String
  sourceType         KnowledgeSourceType
  name               String
  isActive           Boolean             @default(true)
  lastSyncedAt       DateTime?
  metadata           Json?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  
  shop               Shop                @relation(fields: [shopId], references: [id], onDelete: Cascade)
  documents          KnowledgeDocument[]
  
  @@map("knowledge_sources")
}

model KnowledgeDocument {
  id                 String            @id @default(uuid())
  sourceId           String
  externalId         String?           // Shopify product ID, page ID, etc.
  title              String
  language           String            @default("en")
  version            Int               @default(1)
  metadata           Json?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  deletedAt          DateTime?
  
  source             KnowledgeSource   @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  chunks             KnowledgeChunk[]
  
  @@unique([sourceId, externalId])
  @@index([sourceId, externalId])
  @@map("knowledge_documents")
}

model KnowledgeChunk {
  id                 String            @id @default(uuid())
  documentId         String
  sequence           Int
  content            String
  tokenCount         Int?
  metadata           Json?
  createdAt          DateTime          @default(now())
  
  document           KnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  embeddings         EmbeddingRecord[]
  
  @@unique([documentId, sequence])
  @@index([documentId, sequence])
  @@map("knowledge_chunks")
}

model EmbeddingRecord {
  id                 String            @id @default(uuid())
  chunkId            String            @unique
  provider           String            // 'openai', 'gemini', etc.
  model              String
  embedding          Json              // Store as JSON for now, pgvector later
  dimension          Int
  createdAt          DateTime          @default(now())
  
  chunk              KnowledgeChunk    @relation(fields: [chunkId], references: [id], onDelete: Cascade)
  
  @@index([chunkId])
  @@map("embedding_records")
}

// ============================================================================
// COMMERCE PROJECTIONS
// ============================================================================

model ProductProjection {
  id                 String    @id @default(uuid())
  shopId             String
  productId          String
  handle             String
  title              String
  description        String?
  vendor             String?
  productType        String?
  variants           Json?
  images             Json?
  metadata           Json?
  syncedAt           DateTime  @default(now())
  deletedAt          DateTime?
  
  @@unique([shopId, productId])
  @@index([shopId, handle])
  @@map("product_projections")
}

model PolicyProjection {
  id                 String    @id @default(uuid())
  shopId             String
  policyType         String    // 'privacy', 'refund', 'shipping', 'terms'
  title              String
  body               String
  data               Json?     // Full policy data for backward compatibility
  url                String?
  syncedAt           DateTime  @default(now())
  
  @@unique([shopId, policyType])
  @@map("policy_projections")
}

model OrderProjection {
  id                 String    @id @default(uuid())
  shopId             String
  orderId            String
  orderNumber        String
  customerId         String?
  email              String?
  financialStatus    String?
  fulfillmentStatus  String?
  totalPrice         String?
  lineItems          Json?
  data               Json?     // Full order data for backward compatibility
  syncedAt           DateTime  @default(now())
  
  @@unique([shopId, orderId])
  @@index([shopId, customerId])
  @@map("order_projections")
}

// ============================================================================
// ORCHESTRATION
// ============================================================================

model ToolInvocation {
  id                 String              @id @default(uuid())
  messageId          String
  toolName           String
  input              Json
  output             Json?
  success            Boolean
  errorMessage       String?
  durationMs         Int?
  createdAt          DateTime            @default(now())
  
  message            ConversationMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  
  @@index([messageId])
  @@map("tool_invocations")
}

model HandoffRequest {
  id                 String       @id @default(uuid())
  shopId             String
  conversationId     String
  reason             String
  context            Json?        // { lastMessages, detectedIssue, customerSentiment, etc. }
  agentNotes         String?
  status             String       @default("pending") // 'pending', 'assigned', 'completed', 'resolved', 'cancelled'
  assignedTo         String?
  createdAt          DateTime     @default(now())
  resolvedAt         DateTime?
  
  shop               Shop         @relation(fields: [shopId], references: [id], onDelete: Cascade)
  conversation       Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  
  @@index([shopId, status])
  @@index([conversationId])
  @@map("handoff_requests")
}

// ============================================================================
// COMPLIANCE
// ============================================================================

model ConsentRecord {
  id                 String       @id @default(uuid())
  shopId             String
  visitorId          String?
  customerId         String?
  consentType        ConsentType
  granted            Boolean
  ipAddress          String?
  userAgent          String?
  createdAt          DateTime     @default(now())
  revokedAt          DateTime?
  
  shop               Shop         @relation(fields: [shopId], references: [id], onDelete: Cascade)
  
  @@index([shopId, visitorId])
  @@map("consent_records")
}

model AuditLog {
  id                 String    @id @default(uuid())
  shopId             String
  userId             String?
  action             String
  entityType         String?
  entityId           String?
  changes            Json?
  ipAddress          String?
  userAgent          String?
  createdAt          DateTime  @default(now())
  
  shop               Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  
  @@index([shopId, createdAt])
  @@map("audit_logs")
}

// ============================================================================
// SYNC & EVENTS

model DataExportJob {
  id               String   @id @default(uuid())
  shopId           String
  requestedBy      String?  // userId or "visitor:<id>"
  status           String   @default("PENDING") // PENDING, PROCESSING, COMPLETE, FAILED
  exportUrl        String?
  expiresAt        DateTime?
  createdAt        DateTime @default(now())
  completedAt      DateTime?

  shop             Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId, createdAt])
  @@map("data_export_jobs")
}

model DataDeletionJob {
  id               String   @id @default(uuid())
  shopId           String
  requestedBy      String?
  status           String   @default("PENDING") // PENDING, PROCESSING, COMPLETE, FAILED
  recordsDeleted   Int?
  createdAt        DateTime @default(now())
  completedAt      DateTime?

  shop             Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId, createdAt])
  @@map("data_deletion_jobs")
}

// ============================================================================

model WebhookEvent {
  id                 String      @id @default(uuid())
  shopId             String
  topic              String
  payload            Json
  processed          Boolean     @default(false)
  retryCount         Int         @default(0)
  lastError          String?
  processedAt        DateTime?
  createdAt          DateTime    @default(now())
  
  @@index([shopId, processed])
  @@map("webhook_events")
}

model SyncJob {
  id                 String      @id @default(uuid())
  shopId             String
  jobType            String      // 'initial:catalog', 'delta:products', etc.
  status             SyncStatus  @default(PENDING)
  progress           Float       @default(0.0)
  totalItems         Int?
  processedItems     Int         @default(0)
  errorMessage       String?
  startedAt          DateTime?
  completedAt        DateTime?
  createdAt          DateTime    @default(now())
  
  shop               Shop        @relation(fields: [shopId], references: [id], onDelete: Cascade)
  
  @@index([shopId, status])
  @@map("sync_jobs")
}

model OmnichannelCallbackReceipt {
  id                 String    @id @default(uuid())
  shopId             String
  messageId          String
  eventKey           String
  providerMessageId  String?
  requestedStatus    String
  callbackTimestamp  Int
  signatureDigest    String
  applied            Boolean   @default(false)
  createdAt          DateTime  @default(now())

  shop               Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([shopId, eventKey])
  @@index([shopId, messageId, createdAt])
  @@map("omnichannel_callback_receipts")
}

model DeadLetterCallback {
  id                 String    @id @default(uuid())
  shopId             String
  messageId          String
  channel            String    // WEB_CHAT, EMAIL, SMS, etc.
  originalStatus     String    // SENT, DELIVERED, FAILED
  failureReason      String    // "permanent network error", "message not found", etc.
  errorDetails       Json?     // { code, message, statusCode, attempt, ... }
  retryCount         Int       @default(0)
  maxRetries         Int       @default(3)
  nextRetryAt        DateTime?
  isResolved         Boolean   @default(false)
  resolvedAt         DateTime?
  resolvedBy         String?   // "manual", "retry_succeeded", "expired", etc.
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  shop               Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId, createdAt])
  @@index([shopId, isResolved])
  @@index([nextRetryAt])
  @@map("dead_letter_callbacks")
}

// ============================================================================
// PHASE 2: BEHAVIORAL TRACKING & PROACTIVE ENGAGEMENT
// ============================================================================

model BehaviorEvent {
  id                 String    @id @default(uuid())
  shopId             String
  sessionId          String
  visitorId          String?
  customerId         String?
  eventType          String    // PAGE_VIEW, PRODUCT_VIEW, ADD_TO_CART, REMOVE_FROM_CART, EXIT_INTENT, SCROLL_DEPTH, etc.
  eventData          Json      // { productId, dwellTimeMs, scrollDepth, cartValue, etc. }
  timestamp          DateTime  @default(now())
  
  shop               Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  
  @@index([shopId, sessionId])
  @@index([shopId, eventType, timestamp])
  @@index([sessionId, timestamp])
  @@map("behavior_events")
}

model IntentSignal {
  id                 String    @id @default(uuid())
  shopId             String
  sessionId          String
  visitorId          String?
  signalType         String    // BROWSE_INTENT, PURCHASE_INTENT, ABANDONMENT_RISK, NEEDS_HELP, PRICE_SHOPPER, etc.
  confidence         Float     // 0.0 to 1.0
  triggerData        Json      // { dwellTime, productViewCount, cartValue, lastActivity, etc. }
  actionTaken        String?   // PROACTIVE_MESSAGE, RECOMMENDATION, DISCOUNT_OFFER, NONE, etc.
  outcome            String?   // CONVERTED, DISMISSED, IGNORED, ENGAGED, etc.
  createdAt          DateTime  @default(now())
  
  shop               Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  
  @@index([shopId, sessionId])
  @@index([shopId, signalType, createdAt])
  @@index([sessionId, createdAt])
  @@map("intent_signals")
}

model ProactiveTrigger {
  id                 String    @id @default(uuid())
  shopId             String
  name               String
  description        String?
  enabled            Boolean   @default(true)
  triggerType        String    // EXIT_INTENT, DWELL_TIME, CART_ABANDONMENT, PRICE_SENSITIVITY, etc.
  conditions         Json      // { dwellTimeSeconds: 30, productViewCount: 3, cartValueMin: 50, etc. }
  messageTemplate    String    // "Hey! I noticed you're interested in {{productName}}. Need help?"
  priority           Int       @default(0)
  cooldownMs         Int       @default(300000) // 5 minutes default
  targetLocale       String?   // null = all locales
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  
  shop               Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  proactiveMessages  ProactiveMessage[]
  
  @@index([shopId, enabled])
  @@index([shopId, triggerType])
  @@map("proactive_triggers")
}

model ProactiveMessage {
  id                 String    @id @default(uuid())
  shopId             String
  sessionId          String
  triggerId          String
  recipientId        String?
  channel            String    @default("WEB_CHAT")
  messageTemplate    String
  renderedMessage    String
  messageMetadata    Json?
  status             String    @default("QUEUED")
  sentAt             DateTime?
  deliveredAt        DateTime?
  interactedAt       DateTime?
  outcome            String?
  errorMessage       String?
  retryCount         Int       @default(0)
  maxRetries         Int       @default(3)
  expiresAt          DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  shop               Shop             @relation(fields: [shopId], references: [id], onDelete: Cascade)
  trigger            ProactiveTrigger @relation(fields: [triggerId], references: [id], onDelete: Cascade)

  @@index([shopId, createdAt])
  @@index([shopId, status])
  @@index([sessionId, status])
  @@index([triggerId, status])
  @@index([shopId, channel, createdAt])
  @@map("proactive_messages")
}

model ConversionEvent {
  id                 String        @id @default(uuid())
  shopId             String
  conversationId     String
  orderId            String?
  productId          String?
  revenue            Float?        // Revenue attributed to this conversation
  attributionType    String        // DIRECT_RECOMMENDATION, ASSISTED, PROACTIVE_TRIGGER, CART_RECOVERY, etc.
  metadata           Json?         // { products, discount, triggerId, etc. }
  createdAt          DateTime      @default(now())
  
  shop               Shop          @relation(fields: [shopId], references: [id], onDelete: Cascade)
  conversation       Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  
  @@index([shopId, createdAt])
  @@index([conversationId])
  @@index([shopId, attributionType, createdAt])
  @@map("conversion_events")
}
