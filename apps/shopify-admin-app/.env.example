# Shopify App Configuration
SHOPIFY_API_KEY=your_api_key_here
SHOPIFY_API_SECRET=your_api_secret_here
SCOPES=read_products,write_products,read_orders,read_customers,read_content,read_locales,read_online_store_pages

# App URL (use ngrok or cloudflare tunnel for development)
SHOPIFY_APP_URL=https://your-app-url.ngrok-free.app

# Development store URL
SHOPIFY_SHOP=your-store.myshopify.com
SHOPIFY_DEV_STORE_URL=your-store.myshopify.com

# Database (Frontend - Shopify data only)
DATABASE_URL=postgresql://user:password@localhost:5432/fluxbot_dev?schema=public

# Redis (for cache, queues, rate limiting)
REDIS_URL=redis://localhost:6379

# ============================================================================
# IA Gateway Configuration
# ============================================================================
# Controls which AI implementation is used for chat processing.
#
#   remote (default) — delegates to fluxbot-studio-back-ia via HTTP.
#                      Requires IA_BACKEND_URL + IA_BACKEND_API_KEY.
#                      llms.txt generation + intent/trigger decisioning are remote-only.
#                      AI provider API keys are NOT needed in this repo.
#   local            — calls AIOrchestrationService directly in this process.
#                      Requires AI_PROVIDER + the matching provider API key.
#                      Note: intent/trigger decisioning stays disabled in local mode.
#
IA_EXECUTION_MODE=remote

# Backend IA service (only needed when IA_EXECUTION_MODE=remote)
IA_BACKEND_URL=http://localhost:3001
IA_BACKEND_API_KEY=your_ia_backend_api_key

# ============================================================================
# Omnichannel bridge (Phase 3)
# ============================================================================
OMNICHANNEL_BRIDGE_URL=https://your-omnichannel-bridge.example.com
OMNICHANNEL_BRIDGE_TOKEN=your_bridge_api_token
OMNICHANNEL_BRIDGE_WEBHOOK_SECRET=your_callback_hmac_secret
OMNICHANNEL_CALLBACK_MAX_AGE_SECONDS=300

# App Configuration
NODE_ENV=development
SESSION_SECRET=your_session_secret_at_least_32_chars

# Feature Flags
ENABLE_PROACTIVE_TRIGGERS=false
ENABLE_HUMAN_HANDOFF=false
ENABLE_ORDER_LOOKUP=true

# Observability (optional)
SENTRY_DSN=
LOG_LEVEL=info

# Rate Limiting
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000

# Data Retention (days)
CONVERSATION_RETENTION_DAYS=365
BEHAVIOR_EVENT_RETENTION_DAYS=90
