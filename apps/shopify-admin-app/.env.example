# Shopify App Configuration
SHOPIFY_API_KEY=your_api_key_here
SHOPIFY_API_SECRET=your_api_secret_here
SCOPES=read_products,write_products,read_orders,read_customers,read_content,read_locales,read_policies,read_online_store_pages,read_online_store_navigation

# App URL (use ngrok or cloudflare tunnel for development)
SHOPIFY_APP_URL=https://your-app-url.ngrok-free.app

# Development store URL
SHOPIFY_SHOP=your-store.myshopify.com
SHOPIFY_DEV_STORE_URL=your-store.myshopify.com

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/fluxbot_dev?schema=public
# For local development with SQLite (NOT for production)
# DATABASE_URL=file:./dev.sqlite

# Redis (for cache, queues, rate limiting)
REDIS_URL=redis://localhost:6379

# Omnichannel bridge (Phase 3)
OMNICHANNEL_BRIDGE_URL=https://your-omnichannel-bridge.example.com
OMNICHANNEL_BRIDGE_TOKEN=your_bridge_api_token
# Recommended dedicated webhook secret for delivery callbacks
OMNICHANNEL_BRIDGE_WEBHOOK_SECRET=your_callback_hmac_secret
# Max age (seconds) accepted for callback timestamp anti-replay validation
OMNICHANNEL_CALLBACK_MAX_AGE_SECONDS=300

# AI Provider Configuration (choose one or more)
# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Google Gemini
GEMINI_API_KEY=...
GEMINI_MODEL=gemini-2.0-flash-exp

# Default AI Provider (openai|anthropic|gemini)
AI_PROVIDER=openai

# App Configuration
NODE_ENV=development
SESSION_SECRET=your_session_secret_at_least_32_chars

# Feature Flags
ENABLE_PROACTIVE_TRIGGERS=false
ENABLE_HUMAN_HANDOFF=false
ENABLE_ORDER_LOOKUP=true

# Observability (optional)
SENTRY_DSN=
LOG_LEVEL=info

# Rate Limiting
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000

# Data Retention (days)
CONVERSATION_RETENTION_DAYS=365
BEHAVIOR_EVENT_RETENTION_DAYS=90
