# ============================================================
# E2E TEST ENVIRONMENT — ISOLATED FROM DEV AND PRODUCTION
# ============================================================
# This file is loaded by `npm run dev:e2e` and `npm run test:e2e`.
# It points to the dedicated test PostgreSQL on port 5433.
# Never change DATABASE_URL here to port 5432 (dev) or production.

NODE_ENV=test
PORT=3002

# ⚠️  TEST DATABASE ONLY — port 5433, NOT 5432
DATABASE_URL=postgresql://test:test@localhost:5433/test_db?schema=public

# Redis test instance — port 6380, NOT 6379
REDIS_URL=redis://localhost:6380

# Test mode flag: enables auth bypass for E2E (see shopify.server.ts)
E2E_TEST_MODE=true

# Shopify app config (same API key, but URL points to localhost test server)
SHOPIFY_API_KEY=your_api_key_here
# SHOPIFY_API_SECRET must be set locally — copy from .env (never commit real secrets)
SHOPIFY_APP_URL=http://localhost:3002
SHOPIFY_SHOP=quickstart-c8cc9986.myshopify.com

# IA Backend — use dev backend (reads are safe; E2E tests should mock writes)
IA_EXECUTION_MODE=remote
IA_BACKEND_URL=http://localhost:3001
IA_BACKEND_API_KEY=dev_master_key

# Base URL for Playwright tests
E2E_BASE_URL=http://localhost:3002
