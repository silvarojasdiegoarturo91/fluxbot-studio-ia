{
  "name": "@fluxbot/shopify-admin-app",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "bash ./scripts/dev-ngrok.sh",
    "dev:localhost": "bash ./scripts/dev-localhost.sh",
    "dev:ngrok": "bash ./scripts/dev-ngrok.sh",
    "deploy": "shopify app deploy",
    "config:link": "shopify app config link",
    "config:use": "shopify app config use",
    "env": "shopify app env",
    "start": "react-router-serve ./build/server/index.js",
    "docker-start": "npm run setup && npm run start",
    "setup": "npm run prisma:generate && npm run prisma:migrate:deploy",
    "prisma:generate": "prisma generate --schema ../../infra/prisma/schema.prisma",
    "prisma:migrate:dev": "prisma migrate dev --schema ../../infra/prisma/schema.prisma",
    "prisma:migrate:deploy": "prisma migrate deploy --schema ../../infra/prisma/schema.prisma",
    "lint": "eslint --ignore-path ../../.gitignore --cache --cache-location ./node_modules/.cache/eslint .",
    "test": "vitest run",
    "test:phase1:deep": "vitest run test/phase1/chat-e2e.test.ts --reporter=verbose && vitest run test/integration/route-handlers.test.ts test/integration/route-handlers-execution.test.ts test/integration/service-execution.test.ts --reporter=verbose && vitest run test/phase1/chat-e2e.test.ts --coverage --coverage.reporter=text-summary",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "shopify": "shopify",
    "prisma": "prisma",
    "graphql-codegen": "graphql-codegen",
    "vite": "vite",
    "typecheck": "react-router typegen && tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@react-router/dev": "^7.12.0",
    "@react-router/fs-routes": "^7.12.0",
    "@react-router/node": "^7.12.0",
    "@react-router/serve": "^7.12.0",
    "@shopify/app-bridge-react": "^4.2.4",
    "@shopify/shopify-app-react-router": "^1.1.0",
    "@shopify/shopify-app-session-storage-prisma": "^5.1.0",
    "isbot": "^5.1.31",
    "prisma": "^5.22.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router": "^7.12.0",
    "remix-utils": "^9.2.0",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "devDependencies": {
    "@shopify/api-codegen-preset": "^1.2.2",
    "@shopify/app": "latest",
    "@shopify/app-bridge-ui-types": "^0.2.1",
    "@shopify/cli": "latest",
    "@shopify/polaris-types": "^1.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/eslint": "^9.6.1",
    "@types/node": "^22.18.8",
    "@types/react": "^18.3.25",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitest/coverage-v8": "^2.1.8",
    "@vitest/ui": "^2.1.8",
    "eslint": "^8.57.1",
    "eslint-import-resolver-typescript": "^3.10.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "graphql-config": "^5.1.1",
    "jsdom": "^28.1.0",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3",
    "vite": "^6.3.6",
    "vitest": "^2.1.8"
  },
  "trustedDependencies": [
    "@shopify/plugin-cloudflare"
  ],
  "overrides": {
    "p-map": "^4.0.0",
    "@shopify/shopify-api": "^12.3.0"
  }
}
