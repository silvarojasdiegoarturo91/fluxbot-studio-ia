{
  "name": "fluxbot-monorepo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/shopify-admin-app",
    "apps/storefront-widget",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bash ./scripts/dev-fullstack.sh",
    "dev:frontend": "npm --workspace @fluxbot/shopify-admin-app run dev",
    "dev:fullstack": "bash ./scripts/dev-fullstack.sh",
    "shops:sync:ia": "bash ./scripts/sync-ia-shops.sh",
    "smoke:release": "bash ./scripts/smoke-release.sh",
    "build": "npm --workspace @fluxbot/shopify-admin-app run build",
    "typecheck": "npm --workspace @fluxbot/shopify-admin-app run typecheck",
    "lint": "npm --workspace @fluxbot/shopify-admin-app run lint",
    "prisma:generate": "npm --workspace @fluxbot/shopify-admin-app run prisma:generate",
    "prisma:migrate:dev": "npm --workspace @fluxbot/shopify-admin-app run prisma:migrate:dev",
    "prisma:migrate:deploy": "npm --workspace @fluxbot/shopify-admin-app run prisma:migrate:deploy",
    "openspec:status": "node ./scripts/openspec-cli.mjs status",
    "openspec:report:html": "node ./scripts/openspec-cli.mjs report --format html --output reports/openspec-report.html",
    "openspec:report:md": "node ./scripts/openspec-cli.mjs report --format markdown --output reports/openspec-report.md",
    "openspec:report:json": "node ./scripts/openspec-cli.mjs report --format json --output reports/openspec-report.json",
    "openspec:validate": "node ./scripts/openspec-cli.mjs validate",
    "openspec:phases": "node ./scripts/openspec-cli.mjs roadmap",
    "openspec:trace": "node ./scripts/openspec-cli.mjs trace --bidirectional",
    "openspec:risks": "node ./scripts/openspec-cli.mjs risks",
    "openspec:metrics": "node ./scripts/openspec-cli.mjs metrics",
    "openspec:watch": "node ./scripts/openspec-cli.mjs watch",
    "openspec:validate:user-story": "node ./scripts/validate-openspec-user-story.mjs",
    "openspec:validate:strict": "npm run openspec:validate && npm run openspec:validate:user-story",
    "openspec:conflicts": "node ./scripts/check-openspec-conflicts.mjs",
    "openspec:add-req": "node ./scripts/add-requirement.mjs",
    "qa:verify": "node ./scripts/verify-feature.mjs",
    "qa:gate": "npm run contracts:check && npm run openspec:validate:strict && npm run build && npm run lint && npm run typecheck && npm --workspace @fluxbot/shopify-admin-app run test:app-store-compliance && npm --workspace @fluxbot/shopify-admin-app run test",
    "qa:gate:full": "npm run qa:gate && npm --workspace @fluxbot/shopify-admin-app run test:e2e",
    "qa:smoke": "npm --workspace @fluxbot/shopify-admin-app run test:e2e:smoke:ci",
    "githooks:install": "git config core.hooksPath .githooks",
    "contracts:pull": "node ./scripts/pull-contracts.mjs",
    "contracts:check": "node ./scripts/check-contract-version.mjs",
    "api:generate": "npx --yes @hey-api/openapi-ts@0.80.0 -i contracts/fluxbot-ia-api.v1.yaml -o apps/shopify-admin-app/app/generated/ia-api",
    "api:sync": "npm run contracts:pull && npm run api:generate"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.60.3"
  },
  "devDependencies": {
    "openspec": "^0.0.0"
  }
}
