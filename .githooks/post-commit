#!/usr/bin/env sh
set -eu

branch="$(git rev-parse --abbrev-ref HEAD)"

if [ "$branch" = "HEAD" ]; then
  echo "[post-commit] Detached HEAD detected; skipping auto-push."
  exit 0
fi

echo "[post-commit] Auto-pushing branch '$branch' (skip pre-push gate)..."
git push --no-verify --set-upstream origin "$branch" 2>&1 || {
  echo "[post-commit] Push failed. Run manually: git push --no-verify --set-upstream origin $branch"
}
